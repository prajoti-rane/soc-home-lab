<!--
  Rule: SSH Brute Force Detection
  MITRE: T1110.001 — Brute Force: Password Guessing
  Parent SID: 5710 (wazuh sshd failed login)
  Level: 10 (threshold alert), 14 (brute+success compound)
-->
<group name="authentication,brute_force,custom,">

  <!-- Step 1: count 5+ failed SSH attempts from same IP within 60 s -->
  <rule id="100001" level="10" frequency="5" timeframe="60">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <description>SSH brute-force attack detected: 5+ failed logins from $(srcip) in 60 s</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,brute_force,pci_dss_11.4,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.4,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <!-- Step 2: successful login after brute-force (compound kill-chain rule) -->
  <rule id="100002" level="14" timeframe="300">
    <if_matched_sid>100001</if_matched_sid>
    <if_sid>5715</if_sid>
    <same_source_ip />
    <description>SSH brute-force succeeded: attacker $(srcip) logged in after 5+ failures</description>
    <mitre>
      <id>T1110.001</id>
      <id>T1021.004</id>
    </mitre>
    <group>authentication_success,brute_force,pci_dss_10.2.4,pci_dss_10.2.5,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,tsc_CC6.1,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

</group>
