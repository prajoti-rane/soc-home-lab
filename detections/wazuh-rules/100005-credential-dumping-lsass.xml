<!--
  Rule: Credential Dumping via LSASS Access
  MITRE: T1003.001 — OS Credential Dumping: LSASS Memory
  Parent SID: 61612 (Wazuh Sysmon EventID 10 — ProcessAccess)
  Level: 14 (critical — direct LSASS read is almost always malicious)
-->
<group name="credential_dumping,sysmon,windows,custom,">

  <rule id="100005" level="14">
    <if_sid>61612</if_sid>
    <!-- Sysmon EID 10: targetImage must be lsass.exe -->
    <field name="win.eventdata.targetImage" type="pcre2">(?i)\\lsass\.exe$</field>
    <!-- Exclude Windows crash reporter and WER — they legitimately open LSASS -->
    <field name="win.eventdata.sourceImage" type="pcre2" negate="yes">(?i)(WerFault|wermgr|svchost|csrss|services|winlogon|MsMpEng|SecurityHealthService)\.exe$</field>
    <!-- grantedAccess with PROCESS_VM_READ (0x10) component set -->
    <field name="win.eventdata.grantedAccess" type="pcre2">(?i)0x[0-9a-f]*(10|20|38|1F)[0-9a-f]*$</field>
    <description>Credential dumping: $(win.eventdata.sourceImage) opened LSASS with access mask $(win.eventdata.grantedAccess)</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
    <group>credential_dumping,pci_dss_10.6.1,gdpr_IV_35.7.d,hipaa_164.312.a.1,nist_800_53_AU.6,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

</group>
