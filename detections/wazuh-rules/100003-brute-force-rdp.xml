<!--
  Rule: RDP Brute Force Detection
  MITRE: T1110.001 — Brute Force: Password Guessing (RDP vector)
  Parent SID: 60122 (Wazuh Windows EventID 4625 — failed logon)
  Level: 10 (threshold), 14 (brute+success)
-->
<group name="authentication,brute_force,windows,custom,">

  <!-- Step 1: 5+ EventID 4625 (failed logon) from same source IP in 60 s -->
  <rule id="100003" level="10" frequency="5" timeframe="60">
    <if_matched_sid>60122</if_matched_sid>
    <same_source_ip />
    <field name="win.system.eventID" type="pcre2">^4625$</field>
    <description>RDP brute-force attack detected: 5+ Windows logon failures from $(srcip) in 60 s</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,brute_force,pci_dss_11.4,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.4,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

  <!-- Step 2: EventID 4624 (successful logon, type 10 = Remote Interactive) after brute -->
  <rule id="100004" level="14" timeframe="300">
    <if_matched_sid>100003</if_matched_sid>
    <same_source_ip />
    <field name="win.system.eventID" type="pcre2">^4624$</field>
    <field name="win.eventdata.logonType" type="pcre2">^10$</field>
    <description>RDP brute-force succeeded: attacker $(srcip) achieved interactive session</description>
    <mitre>
      <id>T1110.001</id>
      <id>T1021.001</id>
    </mitre>
    <group>authentication_success,brute_force,pci_dss_10.2.4,pci_dss_10.2.5,gdpr_IV_32.2,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,tsc_CC6.1,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

</group>
