<!--
  Rule: Suspicious / Obfuscated PowerShell Execution
  MITRE: T1059.001 — Command and Scripting Interpreter: PowerShell
  Parent SID: 61603 (Wazuh Sysmon EventID 1 — ProcessCreate)
  Level: 12
-->
<group name="execution,powershell,sysmon,windows,custom,">

  <!-- Base: any powershell.exe / pwsh.exe launch -->
  <rule id="100006" level="6">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.image" type="pcre2">(?i)(powershell|pwsh)\.exe$</field>
    <description>PowerShell process spawned: $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <group>execution,powershell,</group>
  </rule>

  <!-- High-severity: obfuscated / hidden / policy-bypass PowerShell -->
  <rule id="100007" level="12">
    <if_sid>100006</if_sid>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-enc|-EncodedCommand|-e\s+[A-Za-z0-9+/]{20,}|-w\s*hid|-WindowStyle\s+Hidden|-NonI|-NoP|-ep\s*Bypass|-ExecutionPolicy\s+Bypass|-noprofile|-noexit\s+-)</field>
    <!-- Exclude SYSTEM-context scheduled-task launchers from Windows Update -->
    <field name="win.eventdata.user" type="pcre2" negate="yes">(?i)SYSTEM$</field>
    <description>Suspicious PowerShell: obfuscation/bypass flags detected — $(win.eventdata.commandLine)</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1027</id>
    </mitre>
    <group>execution,powershell,obfuscation,pci_dss_10.6.1,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.4,tsc_CC6.8,tsc_CC7.2,</group>
  </rule>

  <!-- Critical: encoded command spawned from writable user path -->
  <rule id="100008" level="14">
    <if_sid>100007</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(\\Temp\\|\\AppData\\|\\Downloads\\|\\Users\\[^\\]+\\Desktop\\)</field>
    <description>Critical: Obfuscated PowerShell launched from suspicious parent path $(win.eventdata.parentImage)</description>
    <mitre>
      <id>T1059.001</id>
      <id>T1027</id>
      <id>T1566.001</id>
    </mitre>
    <group>execution,powershell,obfuscation,pci_dss_10.6.1,gdpr_IV_35.7.d,hipaa_164.312.b,nist_800_53_SI.4,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

</group>
