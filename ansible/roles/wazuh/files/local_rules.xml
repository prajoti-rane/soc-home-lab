<!-- Local Wazuh detection rules — SOC Home Lab
     Phase 3 will populate this file with custom rules.
     Rule IDs 100100–100999 are reserved for this lab.
     See detections/wazuh-rules/ for the versioned source of truth.
-->

<group name="soc-lab,custom,">

  <!-- ── Placeholder rules (Phase 3 populates these) ──────────────────────── -->

  <!-- T1059.001 — PowerShell Execution with encoded command -->
  <rule id="100100" level="10">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.image" type="pcre2">(?i)powershell(\.exe)?$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-enc|-encodedcommand|-e\s)</field>
    <description>Possible PowerShell encoded command execution (T1059.001)</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
    <options>no_full_log</options>
  </rule>

  <!-- T1547.001 — Registry Run Key persistence -->
  <rule id="100101" level="10">
    <if_group>sysmon_event13</if_group>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)(\\CurrentVersion\\Run|\\CurrentVersion\\RunOnce)</field>
    <description>Registry Run Key modification — possible persistence (T1547.001)</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
  </rule>

  <!-- T1003.001 — LSASS memory access (credential dumping) -->
  <rule id="100102" level="15">
    <if_group>sysmon_event10</if_group>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)lsass\.exe$</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">^(0x1010|0x1410|0x1fffff|0x143a)$</field>
    <description>Suspicious LSASS process access — possible credential dumping (T1003.001)</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
  </rule>

  <!-- T1055 — Process injection via CreateRemoteThread -->
  <rule id="100103" level="14">
    <if_group>sysmon_event8</if_group>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)(explorer|svchost|lsass|winlogon)\.exe$</field>
    <description>CreateRemoteThread into sensitive process — possible injection (T1055)</description>
    <mitre>
      <id>T1055</id>
    </mitre>
  </rule>

  <!-- T1070.001 — Windows Event Log clearing (EventID 1102) -->
  <!-- Note: rule 18145 already handles this in Wazuh built-ins.
       This rule adds MITRE tagging to the existing detection. -->
  <rule id="100104" level="14">
    <if_sid>18145</if_sid>
    <description>Windows Security event log cleared — possible defense evasion (T1070.001)</description>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>

  <!-- T1071.001 — Suspicious outbound HTTPS from non-browser process -->
  <rule id="100105" level="10">
    <if_group>sysmon_event3</if_group>
    <field name="win.eventdata.destinationPort" type="pcre2">^443$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(temp|appdata|programdata|users\\public).*\.exe</field>
    <description>Outbound HTTPS from process in user-writable path — possible C2 (T1071.001)</description>
    <mitre>
      <id>T1071.001</id>
    </mitre>
  </rule>

</group>
