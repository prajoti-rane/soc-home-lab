# Filebeat Configuration — Windows (Victim Endpoint)
# Managed by Ansible — do not edit manually.
# Template: ansible/roles/filebeat/templates/filebeat-windows.yml.j2

filebeat.inputs:
  # Sysmon events — primary telemetry source
  - type: winlog
    name: sysmon
    event_logs:
      - name: Microsoft-Windows-Sysmon/Operational
        ignore_older: 72h
    fields:
      source: sysmon
      node_name: "{{ inventory_hostname }}"
    fields_under_root: false

  # Windows Security log — authentication, process creation (4688)
  - type: winlog
    name: security
    event_logs:
      - name: Security
        ignore_older: 72h
        event_id: 4624, 4625, 4634, 4648, 4672, 4688, 4697, 4698, 4699,
                  4700, 4701, 4702, 4720, 4722, 4724, 4728, 4732, 4756,
                  1102
    fields:
      source: security
      node_name: "{{ inventory_hostname }}"
    fields_under_root: false

  # Windows System log — service changes, driver loads
  - type: winlog
    name: system
    event_logs:
      - name: System
        ignore_older: 72h
        event_id: 7034, 7035, 7036, 7040, 7045
    fields:
      source: system
      node_name: "{{ inventory_hostname }}"
    fields_under_root: false

  # PowerShell operational log — script block logging
  - type: winlog
    name: powershell
    event_logs:
      - name: Microsoft-Windows-PowerShell/Operational
        ignore_older: 72h
        event_id: 4103, 4104
    fields:
      source: powershell
      node_name: "{{ inventory_hostname }}"
    fields_under_root: false

output.logstash:
  hosts: ["{{ filebeat_logstash_host }}:{{ filebeat_logstash_port }}"]
  bulk_max_size: 1024
  worker: 2

processors:
  - add_host_metadata: ~
  - add_fields:
      target: lab
      fields:
        environment: soc-lab
        role: victim-endpoint

logging.level: warning
logging.to_files: true
logging.files:
  path: "C:\\ProgramData\\filebeat\\logs"
  name: filebeat
  keepfiles: 7
